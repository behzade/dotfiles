#!/usr/bin/env bash
set -euo pipefail

state="$(niri msg -j keyboard-layouts 2>/dev/null || true)"
if [[ -z "$state" ]]; then
  printf '{"text":"--","tooltip":"niri unavailable","class":"unknown"}\n'
  exit 0
fi

current_idx="$(jq -r '.current_idx' <<<"$state")"
current_name="$(jq -r --argjson idx "$current_idx" '.names[$idx]' <<<"$state")"
all_names="$(jq -r '.names | join(" / ")' <<<"$state")"

case "$current_name" in
  "English (US)") short="EN" ; class="english" ;;
  "Persian") short="FA" ; class="persian" ;;
  *) short="$current_name" ; class="other" ;;
esac

jq -cn --arg text "$short" --arg tooltip "$all_names" --arg class "$class" \
  '{text:$text, tooltip:$tooltip, class:$class}'
